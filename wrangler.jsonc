{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "smart-agent-abd-finance",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "routes": [
    {
      "pattern": "smart-agent.abd-finance.co.il",
      "zone_name": "abd-finance.co.il",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "OPS_DB",
      "database_name": "smart-agent",
      "database_id": "973d4cce-1c66-4b73-853a-892d9f4883e0"
    }
  ]
}
